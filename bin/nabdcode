#!/data/data/com.termux/files/usr/bin/bash

# ضمان الخروج النظيف والعودة للشاشة الأصلية دائماً عند انتهاء أو مقاطعة البرنامج
cleanup() {
    printf "\033[?1049l"
}
trap cleanup EXIT INT TERM

# 1. تفعيل درع الشاشة المستقلة (Enter Alternate Screen Buffer)
printf "\033[?1049h"

# 2. تنظيف تامة للشاشة الجديدة لتبدأ البيئة بيضاء ونظيفة
clear

# 3. الانتقال وتشغيل المحرك
cd /data/data/com.termux/files/home/smart-agent
python3 main.py "$@"
